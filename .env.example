# AI プロバイダー設定 (どちらか一方を設定)
ANTHROPIC_API_KEY=sk-ant-xxxxxx
OPENAI_API_KEY=sk-xxxxxx

# 優先する AI プロバイダー: anthropic または openai
AI_PROVIDER=anthropic

# AI モデル設定 (変更不要な場合はそのまま)
# AI_MODEL_ANTHROPIC=claude-haiku-4-5-20251001
# AI_MODEL_OPENAI=gpt-4o-mini

# 仮想ポートフォリオ設定
INITIAL_CAPITAL=1000000.0       # 初期資金 (円)
MAX_POSITION_PCT=0.10           # 1銘柄あたりの最大投資比率 (10%)

# シグナル閾値
BUY_THRESHOLD=65.0              # この値以上で「買い」
SELL_THRESHOLD=35.0             # この値以下で「売り」

# ニュース収集設定
NEWS_PER_SYMBOL=5               # 銘柄ごとの最大取得件数
